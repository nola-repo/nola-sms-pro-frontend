# NOLA SMS Pro frontend env example
# Copy this file into user/.env, agency/.env, or admin/.env as needed.
# Do not put backend secrets in frontend Vite env files.

# Shared frontend API base. Leave blank to use the app's relative /api proxy in local dev.
VITE_API_BASE=https://smspro-api.nolacrm.io
VITE_API_BASE_URL=https://smspro-api.nolacrm.io

# User app SMS/proxy options
VITE_API_SEND_SMS=/webhook/send_sms
VITE_API_SMS_CONTAINER=

# GoHighLevel OAuth. Use the correct app/client for the surface you are running.
VITE_GHL_CLIENT_ID=replace_with_ghl_client_id
VITE_GHL_REDIRECT_URI=https://app.nolasmspro.com/oauth/callback

# Agency app optional fallback. Prefer real session/company resolution in production.
VITE_AGENCY_ID=

# Admin app direct API mode. Usually false for local proxy, true only when intentionally bypassing proxy.
VITE_ADMIN_USE_DIRECT_API=false

# Firebase web config for realtime Firestore reads.
VITE_FIREBASE_API_KEY=replace_with_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=replace_with_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=replace_with_project_id
VITE_FIREBASE_STORAGE_BUCKET=replace_with_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
VITE_FIREBASE_APP_ID=replace_with_app_id

# Backend/runtime-only values below are listed for deployment coordination only.
# Keep them in the backend environment or secret manager, never in browser env files.
JWT_SECRET=backend_only
WEBHOOK_SECRET=backend_only
FIREBASE_SERVICE_ACCOUNT_JSON=backend_only
FIREBASE_CLIENT_EMAIL=backend_only
FIREBASE_PRIVATE_KEY=backend_only
GHL_USER_CLIENT_ID=backend_only
GHL_USER_CLIENT_SECRET=backend_only
GHL_AGENCY_CLIENT_ID=backend_only
GHL_AGENCY_CLIENT_SECRET=backend_only
GHL_SSO_SECRET=backend_only
SEMAPHORE_API_KEY=backend_only
UNISMS_API_KEY=backend_only
UNISMS_WEBHOOK_SECRET=backend_only
NOLA_ALERT_GHL_LOCATION_ID=backend_only
NOLA_ALERT_GHL_TOKEN_REGISTRY_ID=backend_only